# Production Environment Variables
# Copy these to Vercel and Render dashboards

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=3000
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend.com

# ============================================
# DATABASE (Neon)
# ============================================
# Get from: https://neon.tech dashboard
# Format: postgresql://user:pass@host/db?sslmode=require&connection_limit=20&pool_timeout=30
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&connection_limit=20&pool_timeout=30

# ============================================
# JWT
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_FROM_OPENSSL
JWT_EXPIRES_IN=7d

# ============================================
# REDIS (Upstash)
# ============================================
# Get from: https://upstash.com dashboard
REDIS_HOST=xxx-xxx-xxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=AXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REDIS_TLS=true

# ============================================
# CHAPA PAYMENT GATEWAY
# ============================================
# Get from: https://dashboard.chapa.co
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_BASE_URL=https://api.chapa.co/v1

# ============================================
# FIREBASE CLOUD MESSAGING
# ============================================
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=mahber-connect
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@mahber-connect.iam.gserviceaccount.com

# IMPORTANT: Keep the \n for newlines, wrap in quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQCt1k2FJdZY5Bv2\n...\n-----END PRIVATE KEY-----\n"
