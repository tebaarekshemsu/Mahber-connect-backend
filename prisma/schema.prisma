// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  phone              String   @unique // +251XXXXXXXXX format
  password           String // bcrypt hashed
  name               String // Supports Amharic
  email              String?
  bio                String? // Supports Amharic
  is_super_admin     Boolean  @default(false)
  is_suspended       Boolean  @default(false)
  notification_prefs Json? // e.g. { "payments": true, "events": true, "announcements": true, "chat": false }
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  memberships   Membership[]
  join_requests JoinRequest[]
  audit_actions AuditTrail[]
  polls            Poll[]
  notifications    Notification[]
  event_invitations EventInvitation[]
  password_reset_tokens PasswordResetToken[]
  payouts Payout[]
  payouts_approved Payout[] @relation("PayoutApprover")
  events_created Event[] @relation("EventCreatedBy")
  events_hosted  Event[] @relation("EventHost")
  payments Payment[]
  pending_payments PendingPayment[]
  ledger_entries LedgerEntry[]
  fines Fine[]
  fines_waived Fine[] @relation("FineWaiver")
  lotteries_won Lottery[]
  expenses_created Expense[]
  expenses_approved Expense[] @relation("ExpenseApprover")
  attendance_records Attendance[]
  event_photos EventPhoto[]
  announcements_created Announcement[]
  chat_messages ChatMessage[]
  device_tokens DeviceToken[]
  announcement_reads AnnouncementRead[]
  votes Vote[]

  @@map("users")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  code_hash  String    // bcrypt-hashed 6-digit code
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Mahber {
  id              String     @id @default(uuid())
  name            String     @unique
  type            MahberType
  configuration   Json // JSONB field for flexible config
  is_public       Boolean    @default(true)
  is_suspended    Boolean    @default(false)
  invitation_code String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  memberships   Membership[]
  join_requests JoinRequest[]
  payments Payment[]
  pending_payments PendingPayment[]
  ledger_entries LedgerEntry[]
  fines Fine[]
  lotteries Lottery[]
  expenses Expense[]
  payouts Payout[]
  events Event[]
  event_invitations EventInvitation[]
  attendance_records Attendance[]
  event_photos EventPhoto[]
  announcements Announcement[]
  chat_messages ChatMessage[]
  polls Poll[]
  audit_trails AuditTrail[]

  @@map("mahbers")
}

model Membership {
  id                    String           @id @default(uuid())
  mahber_id             String
  member_id             String
  status                MembershipStatus
  role                  Json // JSONB for flexible role structure
  balance               Decimal          @default(0) @db.Decimal(10, 2)
  has_won_current_cycle Boolean          @default(false)
  approval_date         DateTime?
  activation_date       DateTime?
  joined_at             DateTime?
  next_payment_due      DateTime?
  suspended_until       DateTime?
  suspension_reason     String?
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt

  user   User   @relation(fields: [member_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@index([mahber_id, member_id])
  @@index([status, suspended_until])
  @@map("memberships")
}

enum MahberType {
  MAHBER
  EQUB
  IDDIR
}

enum MembershipStatus {
  Pending
  Approved
  Payment_Required
  Active
  Suspended
  Rejected
  Invalidated
  Banned
}

model JoinRequest {
  id               String            @id @default(uuid())
  mahber_id        String
  user_id          String
  status           JoinRequestStatus
  invitation_code  String?
  rejection_reason String?
  is_invitation    Boolean           @default(false)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  user   User   @relation(fields: [user_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@index([mahber_id, user_id])
  @@map("join_requests")
}

enum JoinRequestStatus {
  Pending
  Approved
  Rejected
  Invalidated
}

model Payment {
  id              String        @id @default(uuid())
  mahber_id       String
  member_id       String
  amount          Decimal       @db.Decimal(10, 2)
  payment_type    PaymentType
  status          PaymentStatus
  tx_ref          String        @unique
  chapa_reference String?
  checkout_url    String?
  fine_ids        Json?
  period_start    DateTime?
  period_end      DateTime?
  expires_at      DateTime?
  completed_at    DateTime?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now()) @updatedAt

  member User  @relation(fields: [member_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])
  fines Fine[]
  ledger_entries LedgerEntry[]

  @@index([mahber_id, member_id, status])
  @@map("payments")
}

model PendingPayment {
  id         String   @id @default(uuid())
  mahber_id  String
  member_id  String
  amount     Decimal  @db.Decimal(10, 2)
  status     String   @default("pending") // "pending", "completed", "failed"
  created_at DateTime @default(now())

  member User  @relation(fields: [member_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@index([mahber_id, member_id, status])
  @@map("pending_payments")
}

enum PaymentType {
  Contribution
  JoinFee
  Fine
}

enum PaymentStatus {
  Pending
  Completed
  Failed
  Expired
}

model LedgerEntry {
  id               String          @id @default(uuid())
  mahber_id        String
  member_id        String
  transaction_type TransactionType
  amount           Decimal         @db.Decimal(10, 2)
  running_balance  Decimal         @db.Decimal(10, 2)
  payment_id       String?
  fine_id          String?
  lottery_id       String?
  expense_id       String?
  payout_id        String?
  description      String
  created_at       DateTime        @default(now())

  member  User    @relation(fields: [member_id], references: [id])
  mahber  Mahber  @relation(fields: [mahber_id], references: [id])
  payment Payment? @relation(fields: [payment_id], references: [id])
  fine    Fine?    @relation(fields: [fine_id], references: [id])
  lottery Lottery? @relation(fields: [lottery_id], references: [id])
  expense Expense? @relation(fields: [expense_id], references: [id])
  payout  Payout?  @relation(fields: [payout_id], references: [id])

  @@index([mahber_id, member_id, created_at])
  @@map("ledger_entries")
}

enum TransactionType {
  Contribution
  Fine
  Equb_Payout
  Iddir_Payout
  Payout
  Refund
  Expense
}

model Fine {
  id             String        @id @default(uuid())
  mahber_id      String
  member_id      String
  violation_type ViolationType
  amount         Decimal       @db.Decimal(10, 2)
  is_waived      Boolean       @default(false)
  paid_at        DateTime?
  payment_id     String?
  waiver_reason  String?
  waived_by      String?
  waived_at      DateTime?
  created_at     DateTime      @default(now())

  member         User   @relation(fields: [member_id], references: [id])
  mahber         Mahber @relation(fields: [mahber_id], references: [id])
  payment        Payment? @relation(fields: [payment_id], references: [id])
  waived_by_user User?    @relation("FineWaiver", fields: [waived_by], references: [id])
  ledger_entries LedgerEntry[]

  @@index([mahber_id, member_id])
  @@index([mahber_id, member_id, paid_at])
  @@map("fines")
}

enum ViolationType {
  MISSED_PAYMENT
  MISSED_ATTENDANCE
}

model Lottery {
  id               String   @id @default(uuid())
  mahber_id        String
  winner_id        String
  eligible_members Json
  random_seed      String
  payout_amount    Decimal  @db.Decimal(10, 2)
  created_at       DateTime @default(now())

  mahber         Mahber @relation(fields: [mahber_id], references: [id])
  winner         User   @relation(fields: [winner_id], references: [id])
  ledger_entries LedgerEntry[]

  @@index([mahber_id])
  @@map("lottery_draws")
}

enum ExpenseCategory {
  Operational
  Maintenance
  Event
  Other
  Equb_Payout
}

enum ExpenseStatus {
  Pending
  Rejected
  Paid
  Failed
}

model Expense {
  id                    String          @id @default(uuid())
  mahber_id             String
  amount                Decimal         @db.Decimal(10, 2)
  reason                String
  category              ExpenseCategory
  status                ExpenseStatus   @default(Pending)
  created_by            String
  approved_by           String?
  approved_at           DateTime?
  rejection_reason      String?
  recipient_name        String
  recipient_account_type String          // "bank" or "telebirr"
  recipient_account     String
  recipient_bank_code   String?
  chapa_transfer_ref    String?
  chapa_transfer_status String?
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  mahber         Mahber          @relation(fields: [mahber_id], references: [id])
  creator        User            @relation(fields: [created_by], references: [id])
  approver       User?           @relation("ExpenseApprover", fields: [approved_by], references: [id])
  ledger_entries LedgerEntry[]

  @@index([mahber_id])
  @@index([mahber_id, status])
  @@map("expenses")
}

enum PayoutCategory {
  Iddir_Benefit
  Event_Reimbursement
  Recurring
  General
}

model Payout {
  id            String         @id @default(uuid())
  mahber_id     String
  member_id     String
  amount        Decimal        @db.Decimal(10, 2)
  category      PayoutCategory
  reason        String
  approved_by   String
  paid_at       DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  member  User    @relation(fields: [member_id], references: [id])
  mahber  Mahber  @relation(fields: [mahber_id], references: [id])
  approver User   @relation("PayoutApprover", fields: [approved_by], references: [id])
  ledger_entries LedgerEntry[]

  @@index([mahber_id])
  @@index([mahber_id, member_id])
  @@index([mahber_id, category])
  @@map("payouts")
}

model Event {
  id           String    @id @default(uuid())
  mahber_id    String
  title        String // Supports Amharic
  description  String    @db.Text // Supports Amharic
  event_type   EventType
  start_time   DateTime
  end_time     DateTime
  location     String
  is_mandatory Boolean   @default(false)
  is_cancelled Boolean   @default(false)
  created_by   String?
  host_id      String?
  created_at   DateTime  @default(now())

  recurrence_pattern  EventRecurrence @default(None)
  recurrence_end_date DateTime?
  series_id           String?

  mahber       Mahber @relation(fields: [mahber_id], references: [id])
  invitations  EventInvitation[]
  attendance_records Attendance[]
  event_photos EventPhoto[]

  created_by_user User?  @relation("EventCreatedBy", fields: [created_by], references: [id])
  host_user       User?  @relation("EventHost",       fields: [host_id],   references: [id])

  @@index([mahber_id, start_time])
  @@index([series_id])
  @@map("events")
}

enum EventRecurrence {
  None
  Weekly
  Monthly
}

enum EventType {
  Meeting
  Ceremony
  Fundraiser
  Social_Gathering
}

enum EventInvitationStatus {
  Pending
  Accepted
  Declined
}

model EventInvitation {
  id             String                 @id @default(uuid())
  event_id       String
  mahber_id      String
  member_id      String
  status         EventInvitationStatus  @default(Pending)
  source         String                 @default("admin_invite") // "admin_invite" | "self_register"
  sent_at        DateTime               @default(now())
  responded_at   DateTime?
  channels_used  Json?

  member User  @relation(fields: [member_id], references: [id])
  event  Event @relation(fields: [event_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@unique([event_id, member_id])
  @@index([mahber_id, member_id, status])
  @@map("event_invitations")
}

model Attendance {
  id            String   @id @default(uuid())
  event_id      String
  member_id     String
  mahber_id     String
  checked_in_at DateTime @default(now())

  event  Event  @relation(fields: [event_id], references: [id])
  member User   @relation(fields: [member_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@unique([event_id, member_id])
  @@map("attendance")
}

model EventPhoto {
  cloudinary_public_id String?
  id                   String   @id @default(uuid())
  event_id             String
  mahber_id            String
  uploader_id          String
  file_path            String
  thumbnail_path       String?
  caption              String? // Supports Amharic
  created_at           DateTime @default(now())

  event    Event  @relation(fields: [event_id], references: [id])
  mahber   Mahber @relation(fields: [mahber_id], references: [id])
  uploader User   @relation(fields: [uploader_id], references: [id])

  @@index([event_id, mahber_id])
  @@map("event_photos")
}

model Announcement {
  id              String               @id @default(uuid())
  mahber_id       String
  title           String // Supports Amharic
  content         String               @db.Text // Supports Amharic
  priority        AnnouncementPriority
  target_audience String? // null = all members, or role name
  scheduled_at    DateTime? // null = publish immediately
  is_published    Boolean              @default(false)
  created_by      String // user_id
  created_at      DateTime             @default(now())

  mahber  Mahber @relation(fields: [mahber_id], references: [id])
  creator User   @relation(fields: [created_by], references: [id])
  reads   AnnouncementRead[]

  @@index([mahber_id, created_at])
  @@map("announcements")
}

enum AnnouncementPriority {
  Normal
  Important
  Urgent
}

model AnnouncementRead {
  id              String   @id @default(uuid())
  announcement_id String
  member_id       String
  read_at         DateTime @default(now())

  announcement Announcement @relation(fields: [announcement_id], references: [id])
  member       User        @relation(fields: [member_id], references: [id])

  @@unique([announcement_id, member_id])
  @@map("announcement_reads")
}

model ChatMessage {
  id         String    @id @default(uuid())
  mahber_id  String
  sender_id  String
  content    String    @db.Text
  edited_at  DateTime?
  is_deleted Boolean   @default(false)
  created_at DateTime  @default(now())

  mahber Mahber @relation(fields: [mahber_id], references: [id])
  sender User   @relation(fields: [sender_id], references: [id])
  read_receipts ChatReadReceipt[]

  @@index([mahber_id, created_at])
  @@map("chat_messages")
}

model ChatReadReceipt {
  id         String   @id @default(uuid())
  message_id String
  member_id  String
  read_at    DateTime @default(now())

  message ChatMessage @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@unique([message_id, member_id])
  @@index([member_id, read_at])
  @@map("chat_read_receipts")
}

enum PollType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RANKED_CHOICE
}

model Poll {
  id                   String   @id @default(uuid())
  mahber_id            String
  question             String   @db.Text // Supports Amharic
  options              Json // array of { id: string, text: string }
  poll_type            PollType
  voting_deadline      DateTime
  eligibility_criteria String? // optional role name filter
  is_closed            Boolean  @default(false)
  created_by           String
  created_at           DateTime @default(now())

  mahber Mahber @relation(fields: [mahber_id], references: [id])
  votes  Vote[]
  creator User  @relation(fields: [created_by], references: [id])

  @@index([mahber_id])
  @@map("polls")
}

model Vote {
  id         String   @id @default(uuid())
  poll_id    String
  member_id  String
  choices    Json // array of option IDs
  created_at DateTime @default(now())

  poll   Poll @relation(fields: [poll_id], references: [id])
  member User @relation(fields: [member_id], references: [id])

  @@unique([poll_id, member_id])
  @@map("votes")
}

model DeviceToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  platform   String // ios, android, web
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("device_tokens")
}

model AuditTrail {
  id          String   @id @default(uuid())
  mahber_id   String
  entity_type String // e.g., 'payment', 'membership', 'fine', 'lottery'
  entity_id   String
  action      String // e.g., 'payment_completed', 'status_transition', 'fine_applied'
  actor_id    String? // optional - system actions may not have an actor
  actor       User?    @relation(fields: [actor_id], references: [id])
  mahber      Mahber   @relation(fields: [mahber_id], references: [id])
  old_value   Json?
  new_value   Json?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([mahber_id, entity_type, created_at])
  @@map("audit_trail")
}

enum NotificationType {
  info
  success
  warning
  error
  payment
  event
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  title      String
  message    String           @db.Text
  type       NotificationType @default(info)
  is_read    Boolean          @default(false)
  link       String?
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@map("notifications")
}
