// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  phone      String   @unique // +251XXXXXXXXX format
  password   String // bcrypt hashed
  name       String // Supports Amharic
  email              String?
  bio                String? // Supports Amharic
  notification_prefs Json?   // e.g. { "payments": true, "events": true, "announcements": true, "chat": false }
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  memberships   Membership[]
  join_requests JoinRequest[]
  audit_actions AuditTrail[]
  polls         Poll[]
  notifications Notification[]

  @@map("users")
}

model Mahber {
  id              String     @id @default(uuid())
  name            String     @unique
  type            MahberType
  configuration   Json // JSONB field for flexible config
  is_public       Boolean    @default(true)
  invitation_code String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  memberships   Membership[]
  join_requests JoinRequest[]

  @@map("mahbers")
}

model Membership {
  id                    String           @id @default(uuid())
  mahber_id             String
  member_id             String
  status                MembershipStatus
  role                  Json // JSONB for flexible role structure
  balance               Decimal          @default(0) @db.Decimal(10, 2)
  has_won_current_cycle Boolean          @default(false)
  approval_date         DateTime?
  activation_date       DateTime?
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt

  user   User   @relation(fields: [member_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@index([mahber_id, member_id])
  @@map("memberships")
}

enum MahberType {
  MAHBER
  EQUB
  IDDIR
}

enum MembershipStatus {
  Pending
  Approved
  Payment_Required
  Active
  Suspended
  Rejected
  Invalidated
}

model JoinRequest {
  id               String            @id @default(uuid())
  mahber_id        String
  user_id          String
  status           JoinRequestStatus
  invitation_code  String?
  rejection_reason String?
  is_invitation    Boolean           @default(false)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  user   User   @relation(fields: [user_id], references: [id])
  mahber Mahber @relation(fields: [mahber_id], references: [id])

  @@index([mahber_id, user_id])
  @@map("join_requests")
}

enum JoinRequestStatus {
  Pending
  Approved
  Rejected
  Invalidated
}

model Payment {
  id              String        @id @default(uuid())
  mahber_id       String
  member_id       String
  amount          Decimal       @db.Decimal(10, 2)
  payment_type    PaymentType
  status          PaymentStatus
  tx_ref          String        @unique
  chapa_reference String?
  checkout_url    String?
  completed_at    DateTime?
  created_at      DateTime      @default(now())

  @@index([mahber_id, member_id, status])
  @@map("payments")
}

enum PaymentType {
  Contribution
  JoinFee
  Fine
}

enum PaymentStatus {
  Pending
  Completed
  Failed
}

model LedgerEntry {
  id               String          @id @default(uuid())
  mahber_id        String
  member_id        String
  transaction_type TransactionType
  amount           Decimal         @db.Decimal(10, 2)
  running_balance  Decimal         @db.Decimal(10, 2)
  payment_id       String?
  fine_id          String?
  lottery_id       String?
  description      String
  created_at       DateTime        @default(now())

  @@index([mahber_id, member_id, created_at])
  @@map("ledger_entries")
}

enum TransactionType {
  Contribution
  Fine
  Equb_Payout
  Iddir_Payout
  Refund
}

model Fine {
  id             String        @id @default(uuid())
  mahber_id      String
  member_id      String
  violation_type ViolationType
  amount         Decimal       @db.Decimal(10, 2)
  is_waived      Boolean       @default(false)
  waiver_reason  String?
  waived_by      String?
  waived_at      DateTime?
  created_at     DateTime      @default(now())

  @@index([mahber_id, member_id])
  @@map("fines")
}

enum ViolationType {
  MISSED_PAYMENT
  MISSED_ATTENDANCE
}

model Lottery {
  id               String   @id @default(uuid())
  mahber_id        String
  winner_id        String
  eligible_members Json
  random_seed      String
  payout_amount    Decimal  @db.Decimal(10, 2)
  created_at       DateTime @default(now())

  @@index([mahber_id])
  @@map("lottery_draws")
}

model Event {
  id           String    @id @default(uuid())
  mahber_id    String
  title        String // Supports Amharic
  description  String    @db.Text // Supports Amharic
  event_type   EventType
  start_time   DateTime
  end_time     DateTime
  location     String
  is_mandatory Boolean   @default(false)
  is_cancelled Boolean   @default(false)
  created_at   DateTime  @default(now())

  @@index([mahber_id, start_time])
  @@map("events")
}

enum EventType {
  Meeting
  Ceremony
  Fundraiser
  Social_Gathering
}

model Attendance {
  id           String   @id @default(uuid())
  event_id     String
  member_id    String
  mahber_id    String
  checked_in_at DateTime @default(now())

  @@unique([event_id, member_id])
  @@map("attendance")
}

model EventPhoto {
  cloudinary_public_id String?
  id             String   @id @default(uuid())
  event_id       String
  mahber_id      String
  uploader_id    String
  file_path      String
  thumbnail_path String?
  caption        String? // Supports Amharic
  created_at     DateTime @default(now())

  @@index([event_id, mahber_id])
  @@map("event_photos")
}

model Announcement {
  id              String               @id @default(uuid())
  mahber_id       String
  title           String // Supports Amharic
  content         String               @db.Text // Supports Amharic
  priority        AnnouncementPriority
  target_audience String? // null = all members, or role name
  scheduled_at    DateTime? // null = publish immediately
  is_published    Boolean              @default(false)
  created_by      String // user_id
  created_at      DateTime             @default(now())

  reads AnnouncementRead[]

  @@index([mahber_id, created_at])
  @@map("announcements")
}

enum AnnouncementPriority {
  Normal
  Important
  Urgent
}

model AnnouncementRead {
  id              String       @id @default(uuid())
  announcement_id String
  member_id       String
  read_at         DateTime     @default(now())

  announcement Announcement @relation(fields: [announcement_id], references: [id])

  @@unique([announcement_id, member_id])
  @@map("announcement_reads")
}

model ChatMessage {
  id         String    @id @default(uuid())
  mahber_id  String
  sender_id  String
  content    String    @db.Text
  edited_at  DateTime?
  is_deleted Boolean   @default(false)
  created_at DateTime  @default(now())

  @@index([mahber_id, created_at])
  @@map("chat_messages")
}

enum PollType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

model Poll {
  id                   String    @id @default(uuid())
  mahber_id            String
  question             String    @db.Text // Supports Amharic
  options              Json // array of { id: string, text: string }
  poll_type            PollType
  voting_deadline      DateTime
  eligibility_criteria String? // optional role name filter
  is_closed            Boolean   @default(false)
  created_by           String
  created_at           DateTime  @default(now())

  votes   Vote[]
  creator User   @relation(fields: [created_by], references: [id])

  @@index([mahber_id])
  @@map("polls")
}

model Vote {
  id         String   @id @default(uuid())
  poll_id    String
  member_id  String
  choices    Json // array of option IDs
  created_at DateTime @default(now())

  poll Poll @relation(fields: [poll_id], references: [id])

  @@unique([poll_id, member_id])
  @@map("votes")
}

model DeviceToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  platform   String // ios, android, web
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("device_tokens")
}

model AuditTrail {
  id          String   @id @default(uuid())
  mahber_id   String
  entity_type String // e.g., 'payment', 'membership', 'fine', 'lottery'
  entity_id   String
  action      String // e.g., 'payment_completed', 'status_transition', 'fine_applied'
  actor_id    String? // optional - system actions may not have an actor
  actor       User?    @relation(fields: [actor_id], references: [id])
  old_value   Json?
  new_value   Json?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([mahber_id, entity_type, created_at])
  @@map("audit_trail")
}

enum NotificationType {
  info
  success
  warning
  error
  payment
  event
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  title      String
  message    String           @db.Text
  type       NotificationType @default(info)
  is_read    Boolean          @default(false)
  link       String?
  created_at DateTime         @default(now())

  user       User             @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@map("notifications")
}
